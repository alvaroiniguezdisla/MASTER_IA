# OpenAI
OPENAI_API_KEY=sk-tu_clave_openai
OPENAI_MODEL=gpt-4o-mini

# ExchangeRate-API: https://www.exchangerate-api.com/
API_KEY_EXCHANGE=tu_api_key_aqui
BASE_URL_EXCHANGE=https://v6.exchangerate-api.com/v6/{API_KEY_EXCHANGE}/latest/{MONEDA}

# Open-Meteo no requiere API key
BASE_URL_WEATHER=https://api.open-meteo.com/v1/
BASE_URL_GEOCODING=https://geocoding-api.open-meteo.com/v1/search

# Servidor MCP local
MCP_HOST=127.0.0.1
MCP_PORT=8000
MCP_PATH=/mcp/
MCP_SERVER_URL=http://localhost:8000/mcp/

# Logging
LOG_LEVEL=INFO
